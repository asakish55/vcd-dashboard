# ─────────────────────────────────────────────────────────────────────────────
# VCD Dashboard – Environment Variables Example
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Edit .env with your actual values
#   3. NEVER commit .env to git (it's in .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ── VCD Connection (entered in the dashboard UI – not required here) ────────
# These are kept as reference. The actual connection is done via the dashboard.
VCD_HOST=https://your-vcd-host.example.com
VCD_DEFAULT_ORG=System

# ── Docker / Port Configuration ────────────────────────────────────────────
# Port on which the dashboard is accessible
FRONTEND_PORT=80

# ── Backend Configuration ───────────────────────────────────────────────────
BACKEND_PORT=8000
LOG_LEVEL=info

# ── Optional: SSL/TLS (for production HTTPS) ───────────────────────────────
# If you want HTTPS, configure certificates and update nginx.conf
# SSL_CERT_PATH=/etc/ssl/certs/vcd-dashboard.crt
# SSL_KEY_PATH=/etc/ssl/private/vcd-dashboard.key
